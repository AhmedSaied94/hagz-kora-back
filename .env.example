# ============================================================
# Hagz Kora — Environment Variables Reference
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# Django core
SECRET_KEY=your-secret-key-here-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.local

# Auth backend: "phone" (production OTP) | "email" (dev/staging)
DJANGO_AUTH_BACKEND=email

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=hagzkora
POSTGRES_USER=hagzkora
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Production only — password required:
REDIS_PASSWORD=

# ── CORS (comma-separated origins) ──────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── SMS / OTP (production only) ──────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Firebase Cloud Messaging ──────────────────────────────────
FCM_SERVER_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── S3 / Object Storage (production) ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=hagzkora-media
AWS_S3_REGION_NAME=eu-central-1
AWS_S3_CUSTOM_DOMAIN=

# ── Email (production SMTP) ───────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@hagzkora.com

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=
